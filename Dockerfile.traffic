# Multi-arch image for the failover-demo traffic app (cmd/traffic-app).
FROM --platform=$BUILDPLATFORM golang:1.26 AS build
ARG TARGETOS TARGETARCH
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o /traffic-app ./cmd/traffic-app

FROM gcr.io/distroless/static-debian12
COPY --from=build /traffic-app /traffic-app
ENTRYPOINT ["/traffic-app"]
